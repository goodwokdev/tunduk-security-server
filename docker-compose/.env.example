# Скопируй в .env и заполни. НИКОГДА не коммить настоящий .env (см. .gitignore).
#   cp .env.example .env && $EDITOR .env

# --- PIN программного токена (SoftToken) -------------------------------------
# Защищает приватные ключи в программном токене. Минимум 15 символов, верхний и
# нижний регистр + цифры + знаки. ПОТЕРЯЕШЬ = все сертификаты придётся перевыпускать.
# Должен совпадать с PIN, который ты вводишь в панели при первичной настройке.
XROAD_TOKEN_PIN=change-me-Min15Chars!

# --- Учётка админ-панели ------------------------------------------------------
# Логин в админ-панель сервера безопасности на https://<host>:4000
XROAD_ADMIN_USER=xrd-admin
XROAD_ADMIN_PASSWORD=change-me-strong-password

# --- База данных --------------------------------------------------------------
# Пароль суперпользователя PostgreSQL. Используется и контейнером postgres:12, и
# сервером безопасности (он подключается суперпользователем и сам создаёт базы/роли).
XROAD_DB_PWD=change-me-db-superuser-password

# --- Логирование --------------------------------------------------------------
XROAD_LOG_LEVEL=INFO

# --- Привязка портов (необязательные переопределения) ------------------------
# Админ-панель + health по умолчанию на loopback; доступ к панели через SSH-туннель:
#   ssh -L 4000:127.0.0.1:4000 <vm>
# Чтобы открыть панель напрямую (НЕ рекомендуется), задай XROAD_ADMIN_BIND=0.0.0.0
#XROAD_ADMIN_BIND=127.0.0.1
#XROAD_HEALTH_BIND=127.0.0.1

# Точки доступа информационных систем. По умолчанию = loopback (ИС на той же виртуалке).
# Чтобы принимать соединения от внутренней ИС на классических 80/443 (вики, п. 1.7):
#XROAD_IS_HTTP_PORT=80
#XROAD_IS_HTTPS_PORT=443
