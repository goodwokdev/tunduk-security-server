# Copy to .env and fill in. NEVER commit the real .env (see .gitignore).
#   cp .env.example .env && $EDITOR .env

# --- SoftToken PIN -----------------------------------------------------------
# Protects the private keys in the software token. Min 15 chars, mixed case +
# digits + symbols. LOSE THIS = all certificates must be reissued.
# Must match the PIN you enter in the UI during initial configuration.
XROAD_TOKEN_PIN=change-me-Min15Chars!

# --- Admin UI credentials ----------------------------------------------------
# Login for the security server admin UI at https://<host>:4000
XROAD_ADMIN_USER=xrd-admin
XROAD_ADMIN_PASSWORD=change-me-strong-password

# --- Database ----------------------------------------------------------------
# PostgreSQL superuser password. Used by both the postgres:12 container and the
# security server (it connects as superuser to auto-create its databases/roles).
XROAD_DB_PWD=change-me-db-superuser-password

# --- Logging -----------------------------------------------------------------
XROAD_LOG_LEVEL=INFO

# --- Port binding (optional overrides) ---------------------------------------
# Admin UI + health bind to loopback by default; reach the UI via SSH tunnel:
#   ssh -L 4000:127.0.0.1:4000 <vm>
# To expose the UI directly (NOT recommended), set XROAD_ADMIN_BIND=0.0.0.0
#XROAD_ADMIN_BIND=127.0.0.1
#XROAD_HEALTH_BIND=127.0.0.1

# Information-system access points. Default = loopback (IS runs on the same VM).
# To accept connections from an internal IS on the classic 80/443 (wiki ref 1.7):
#XROAD_IS_HTTP_PORT=80
#XROAD_IS_HTTPS_PORT=443
